# AI Personality Eval v0.1
# Copy to .env for local use. Do not commit real keys.

# OpenAI-compatible gateway. For this workspace, the concrete Boyue values live in:
# /mnt/shared-storage-gpfs2/sciprismax2/zhouzhiwang/docs/platform/model-access/model-access.env.sh
OPENAI_BASE_URL=http://35.220.164.252:3888/v1/
OPENAI_API_KEY=replace_with_gateway_key

# One model or a comma-separated batch.
MODEL_ACCESS_DEFAULT_MODEL=gpt-4o-mini
EVAL_MODELS=gpt-5.4,gpt-4o-mini,claude-opus-4-6,qwen3.5-plus,MiniMax-M2.7,deepseek-v3.2,grok-4,kimi-k2.5

# Test pack.
EVAL_TEST_PACK=ai-personality-v0.1
EVAL_TEMPERATURE=0.2
EVAL_MAX_TOKENS=512
EVAL_SEED=7

# Retry and timeout.
MODEL_ACCESS_MAX_RETRIES=3
MODEL_ACCESS_RETRY_BACKOFF_SECONDS=2
MODEL_ACCESS_TIMEOUT_SECONDS=120

# Output.
EVAL_OUTPUT_DIR=runs/personality-eval
